# Copy to .env.local and fill in. See docs/DEPLOYMENT.md for where each value comes from.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL — used to build OAuth redirect URIs and links in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token encryption — AES-256 key for encrypting Google OAuth tokens at rest
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Cron secret — shared secret between pg_cron and the API routes it calls
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Google OAuth — Google Cloud Console → APIs & Services → Credentials
# Requires Business Profile API access approval first (see docs/DEPLOYMENT.md Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=

# Resend — weekly digest email
RESEND_API_KEY=
RESEND_FROM="Reviews Analytics <digest@reviewsanalytics.ai>"
