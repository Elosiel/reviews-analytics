# ── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.reviewsanalytics.ai
# Local dev: NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────
# supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase pg_cron (called by cron jobs back into the app) ────────
# A long random secret shared between the DB cron job and the API routes
# that the cron job calls. Prevents public triggering of sync/digest endpoints.
CRON_SECRET=your-random-secret-min-32-chars

# ── Token encryption key (AES-256) ──────────────────────────────────
# Used to encrypt Google access_token + refresh_token at rest.
# 32-byte hex string. Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ── Google Cloud OAuth ───────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# Enable APIs:
#   - Google Business Profile API
#   - My Business Business Information API
# OAuth 2.0 redirect URIs:
#   https://app.reviewsanalytics.ai/api/google/callback
#   http://localhost:3000/api/google/callback (dev)
#
# IMPORTANT: This product is READ-ONLY. We never post on the tenant's behalf.
# Scope used: https://www.googleapis.com/auth/business.manage
# (Verify this is still the minimal scope for reviews.list — see src/lib/google/oauth.ts)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Anthropic Claude (sentiment analysis engine) ────────────────────
# console.anthropic.com → API keys
# Model: claude-sonnet (or latest). No OpenAI.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Resend (weekly Monday digest emails) ────────────────────────────
# resend.com → API keys
# From address should be a verified domain (e.g. digest@reviewsanalytics.ai)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=digest@reviewsanalytics.ai
